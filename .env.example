# ─── WhatsApp Bot Panel — Environment Config ───────────────────────────────────
# Copy this to .env and fill in your values

# JWT secret — CHANGE THIS before deploying!
JWT_SECRET=replace-with-a-long-random-secret-32-chars-min

# Admin default password (only used on first run to seed DB)
ADMIN_PASSWORD=Admin@1234

# Backend port
BACKEND_PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Set to your Replit URL in production:
# FRONTEND_URL=https://your-replit-username.your-replit-slug.repl.co
